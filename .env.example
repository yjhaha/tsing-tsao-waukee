# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_KITCHEN_PIN=1234

# ── Restaurant info ───────────────────────────────────────────────────────────
RESTAURANT_NAME=Tsing Tsao Waukee
RESTAURANT_EMAIL=tsingtsaowaukee@gmail.com
RESTAURANT_PHONE=(515) 830-9600
RESTAURANT_ADDRESS_STREET=160 SE Laurel St
RESTAURANT_ADDRESS_CITY=Waukee
RESTAURANT_ADDRESS_STATE=IA
RESTAURANT_ADDRESS_ZIP=50263
RESTAURANT_LAT=41.6132
RESTAURANT_LNG=-93.8692
# These two must be NEXT_PUBLIC_ so the success page map can use them client-side
NEXT_PUBLIC_RESTAURANT_LAT=41.6132
NEXT_PUBLIC_RESTAURANT_LNG=-93.8692

# ── Delivery provider (uber | doordash) ───────────────────────────────────────
DELIVERY_PROVIDER=uber

# Uber Direct
UBER_CLIENT_ID=...
UBER_CLIENT_SECRET=...
UBER_CUSTOMER_ID=...           # UUID from direct.uber.com → Settings → API
UBER_API_BASE=https://sandbox-api.uber.com/v1   # remove this line for production
UBER_WEBHOOK_SECRET=...        # optional — set in direct.uber.com → Settings → Webhooks

# DoorDash Drive (if using doordash provider instead)
# DOORDASH_DEVELOPER_ID=...
# DOORDASH_KEY_ID=...
# DOORDASH_SIGNING_SECRET=...
# DOORDASH_WEBHOOK_SECRET=...

# ── Maps (optional — enables route map on success page + in emails) ───────────
# Get a key at console.cloud.google.com → Maps Static API + Maps Embed API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=...   # client-side (success page map)
GOOGLE_MAPS_KEY=...               # server-side (email static map image)
